<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="StarlightGUI.DeuteriumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:StarlightGUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Padding="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Padding="5">
                    <TextBlock
                        HorizontalAlignment="Left"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Deuterium Proxy" />
                    <TextBlock
                        Padding="0,0,0,0"
                        HorizontalAlignment="Left"
                        FontSize="14"
                        FontStyle="Italic"
                        Foreground="LightGray"
                        Text="/* Extremely powerful tool for kernel-level function invoking and debugging... */" />
                </StackPanel>
                <Button
                    Grid.Column="2"
                    Click="ExecuteButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Glyph="&#xe945;" />
                        <TextBlock Margin="5,0,0,0" Text="执行" />
                    </StackPanel>
                </Button>
            </Grid>
            <ScrollViewer
                Grid.Row="1"
                Margin="20,0,20,10"
                Padding="10,0,10,0"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="5">
                <essential:RevealFocusPanel x:Name="RevealFocusPanel">
                    <StackPanel>
                        <StackPanel Margin="10,10,0,0" Orientation="Horizontal">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe794;" />
                            <TextBlock Margin="10,0,0,0" Text="函数设置" />
                        </StackPanel>
                        <Expander
                            Margin="0,10,0,20"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            essential:RevealFocusPanel.AttachToPanel="{x:Bind RevealFocusPanel}"
                            Header="函数"
                            IsExpanded="True">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xeb19;" />
                                    <TextBlock Margin="10,0,0,0" Text="函数地址" />
                                </StackPanel>
                                <TextBox x:Name="FunctionAddressBox" Margin="0,0,0,15" />
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xe751;" />
                                    <TextBlock Margin="10,6,0,0" Text="返回类型" />
                                    <ComboBox
                                        x:Name="FunctionReturnBox"
                                        Margin="20,0,0,0"
                                        essential:ComboBoxHelper.AcrylicWorkaround="True"
                                        PlaceholderText="选择返回类型">
                                        <ComboBoxItem Content="LONG" />
                                        <ComboBoxItem Content="LONG64" />
                                        <ComboBoxItem Content="ULONG" />
                                        <ComboBoxItem Content="ULONG64" />
                                        <ComboBoxItem Content="CHAR" />
                                        <ComboBoxItem Content="UCHAR" />
                                        <ComboBoxItem Content="WCHAR" />
                                        <ComboBoxItem Content="SHORT" />
                                        <ComboBoxItem Content="USHORT" />
                                        <ComboBoxItem Content="BOOLEAN" />
                                        <ComboBoxItem Content="PVOID" />
                                        <ComboBoxItem Content="NULLABLE" IsEnabled="False" />
                                        <ComboBoxItem Content="VOID" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <FontIcon
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="14"
                                        Glyph="&#xe723;" />
                                    <TextBlock Margin="10,6,0,0" Text="附加进程" />
                                    <CheckBox x:Name="FunctionAttachBox" Margin="20,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                        <StackPanel Margin="10,0,0,0" Orientation="Horizontal">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xe8fd;" />
                            <TextBlock Margin="10,0,0,0" Text="参数数量" />
                        </StackPanel>
